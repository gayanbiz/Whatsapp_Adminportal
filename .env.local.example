# PostgreSQL connection string (pooled — for Prisma queries)
# NOTE: ?pgbouncer=true is required when using Supabase Transaction pooler (port 6543)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection string (for migrations — bypasses pooler)
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# JWT Secret — use a long random string in production
JWT_SECRET="whatsapp-print-manager-secret-key-change-me"

# Admin credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# ── Vercel deployment ──────────────────────────────────────
# Set all variables above in: Vercel Dashboard → Project → Settings → Environment Variables
# Root Directory must be set to: admin-portal
